# Sabiá OAuth2 credentials — obtenha no portal de aplicações do Sabiá
SABIA_CLIENT_ID=seu-client-id-aqui
SABIA_CLIENT_SECRET=seu-client-secret-aqui
SABIA_REDIRECT_URI=http://localhost:8000/auth/sabia/callback/

# Opcional — URLs padrão do Sabiá (não altere a menos que use um ambiente diferente)
# SABIA_BASE_URL=https://login.sabia.ufrn.br
# SABIA_API_URL=https://api.sabia.ufrn.br
# SABIA_SCOPES=cpf email

# Django
# DJANGO_SECRET_KEY=troque-por-uma-chave-segura
# DJANGO_DEBUG=True
# DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1
